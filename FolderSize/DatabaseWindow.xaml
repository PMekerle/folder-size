<ui:FluentWindow x:Class="FolderSize.DatabaseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Scan Database"
        Icon="Assets/icon.ico"
        Width="1200" Height="720"
        MinWidth="700" MinHeight="400"
        FontSize="12"
        WindowStartupLocation="CenterOwner"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Scan Database" ShowMaximize="True" ShowMinimize="True"/>

        <Grid Grid.Row="1" Margin="16,12,16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Saved scans" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
            <ui:Button Grid.Column="1" Content="Refresh" Click="Refresh_Click"/>
        </Grid>

        <DataGrid Grid.Row="2" x:Name="Grid"
                  Margin="16,0,16,8"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  GridLinesVisibility="None"
                  CanUserAddRows="False"
                  RowHeight="32"
                  BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                  BorderThickness="1"
                  Background="{DynamicResource ControlFillColorDefaultBrush}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="2*" MinWidth="200"/>
                <DataGridTextColumn Header="Scanned" Binding="{Binding ScannedText}" Width="260"/>
                <DataGridTextColumn Header="Size" Binding="{Binding SizeText}" Width="85"/>
                <DataGridTextColumn Header="On disk" Binding="{Binding SizeOnDiskText}" Width="85"/>
                <DataGridTextColumn Header="Files" Binding="{Binding FileCountText}" Width="80"/>
                <DataGridTextColumn Header="Duration" Binding="{Binding DurationText}" Width="90"/>
                <DataGridTextColumn Header="DB size" Binding="{Binding BlobSizeText}" Width="80"/>
                <DataGridTemplateColumn Header="" Width="190">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <ui:Button Margin="4,2,2,2" Click="Rescan_Click" Tag="{Binding Path}">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="ArrowSync24" FontSize="14" Margin="0,0,4,0"/>
                                        <TextBlock Text="Rescan" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </ui:Button>
                                <ui:Button Margin="2,2,4,2" Click="Delete_Click" Tag="{Binding Path}">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Delete24" FontSize="14" Margin="0,0,4,0"/>
                                        <TextBlock Text="Delete" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </ui:Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="3" Padding="16,8,16,12"
                Background="{DynamicResource ControlFillColorDefaultBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="StatusText" VerticalAlignment="Center" Opacity="0.85"/>
                <ui:Button Grid.Column="1" Content="Close" Click="Close_Click"/>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
