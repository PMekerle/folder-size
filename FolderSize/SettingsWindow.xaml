<ui:FluentWindow x:Class="FolderSize.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Settings"
        Icon="Assets/icon.ico"
        Width="720" Height="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        FontSize="12">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Settings" ShowMaximize="False" ShowMinimize="False"/>

        <StackPanel Grid.Row="1" Margin="24,16,24,16">
            <TextBlock Text="Display" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Theme:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="ThemeBox" Width="160" SelectionChanged="ThemeBox_SelectionChanged">
                    <ComboBoxItem Content="System default" Tag="System"/>
                    <ComboBoxItem Content="Light" Tag="Light"/>
                    <ComboBoxItem Content="Dark" Tag="Dark"/>
                </ComboBox>
            </StackPanel>
            <CheckBox x:Name="ShowFilesBox" Content="Show individual files by default (otherwise grouped as 'N files')"
                      Margin="0,0,0,6" Click="ShowFilesBox_Click"/>
            <CheckBox x:Name="AutoExpandBox" Content="Auto-expand navigation tree when clicking a folder"
                      Margin="0,0,0,6" Click="AutoExpandBox_Click"/>
            <CheckBox x:Name="HideCloseSizeBox" Content="Hide 'size on disk' when it's within 1% of the logical size"
                      Margin="0,0,0,16" Click="HideCloseSizeBox_Click"/>

            <TextBlock Text="Windows Explorer integration" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
            <TextBlock Text="Adds a 'Folder Size' entry to the right-click menu on folders, drives, and inside folder backgrounds. Clicking it opens Folder Size on that path (auto-scans if not cached)." TextWrapping="Wrap" Opacity="0.8" Margin="0,0,0,12"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="Status:" Margin="0,0,6,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="StatusText" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,8,0,8">
                <ui:Button x:Name="RegisterBtn" Content="Register" Click="Register_Click" Appearance="Primary" MinWidth="110" Margin="0,0,8,0"/>
                <ui:Button x:Name="UnregisterBtn" Content="Unregister" Click="Unregister_Click" MinWidth="110"/>
            </StackPanel>

            <TextBlock Text="Note: Windows 11 shows legacy context menu items under 'Show more options' in the right-click menu. Hold Shift while right-clicking to skip the modern menu and see this entry directly." TextWrapping="Wrap" Opacity="0.6" FontSize="11" Margin="0,12,0,0"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
