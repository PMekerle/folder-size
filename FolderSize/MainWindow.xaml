<ui:FluentWindow x:Class="FolderSize.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:FolderSize.ViewModels"
        xmlns:conv="clr-namespace:FolderSize.Converters"
        Title="Folder Size"
        Icon="Assets/icon.ico"
        AllowDrop="True"
        Drop="Window_Drop"
        DragEnter="Window_DragOver"
        DragOver="Window_DragOver"
        Height="780" Width="1280"
        MinHeight="400" MinWidth="700"
        FontSize="12"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">

    <Window.Resources>
        <conv:MetricValueConverter x:Key="MetricValueConverter"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:BarFractionToWidthConverter x:Key="BarFractionToWidth"/>
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="SegmentedRadio" TargetType="RadioButton">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root"
                                Background="Transparent"
                                CornerRadius="4"
                                Padding="10,4"
                                Margin="1,0">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="" ShowMaximize="True" ShowMinimize="True">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Width="16" Height="16">
                    <ui:ImageIcon.Source>
                        <BitmapImage UriSource="pack://application:,,,/Assets/icon.png" DecodePixelWidth="32"/>
                    </ui:ImageIcon.Source>
                </ui:ImageIcon>
            </ui:TitleBar.Icon>
            <ui:TitleBar.Header>
                <TextBlock Text="Folder Size"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="-8,1,0,0"/>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <Grid Grid.Row="1" Margin="16,8,16,8" Height="36">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ui:Button Grid.Column="0" Height="36" Width="36" Padding="0"
                       ToolTip="Back (Alt+Left / mouse X1)"
                       IsEnabled="{Binding CanGoBack}"
                       Click="Back_Click">
                <ui:SymbolIcon Symbol="ArrowLeft24"/>
            </ui:Button>
            <ui:Button Grid.Column="1" Height="36" Width="36" Padding="0" Margin="4,0,0,0"
                       ToolTip="Forward (Alt+Right / mouse X2)"
                       IsEnabled="{Binding CanGoForward}"
                       Click="Forward_Click">
                <ui:SymbolIcon Symbol="ArrowRight24"/>
            </ui:Button>
            <ui:Button Grid.Column="2" Height="36" Width="36" Padding="0" Margin="4,0,8,0"
                       ToolTip="Up one level (Alt+Up)"
                       IsEnabled="{Binding CanGoUp}"
                       Click="Up_Click">
                <ui:SymbolIcon Symbol="ArrowUp24"/>
            </ui:Button>

            <ui:TextBox x:Name="PathBox" Grid.Column="3"
                        Height="36"
                        Text="{Binding PathInput, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="Type a path and press Enter to scan, or double-click a folder in the tree"
                        KeyDown="PathBox_KeyDown"/>

            <Border Grid.Column="4" Margin="8,0,0,0" Padding="3"
                    Height="36"
                    CornerRadius="4"
                    VerticalAlignment="Center"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <RadioButton Style="{StaticResource SegmentedRadio}"
                                 GroupName="Metric" Content="Size"
                                 IsChecked="{Binding IsMetricSize, Mode=TwoWay}"/>
                    <RadioButton Style="{StaticResource SegmentedRadio}"
                                 GroupName="Metric" Content="Size on disk"
                                 IsChecked="{Binding IsMetricSizeOnDisk, Mode=TwoWay}"/>
                    <RadioButton Style="{StaticResource SegmentedRadio}"
                                 GroupName="Metric" Content="Number of files"
                                 IsChecked="{Binding IsMetricFileCount, Mode=TwoWay}"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="16,0,16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="200"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="320"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    BorderThickness="0"
                    Background="Transparent">
                <TreeView x:Name="ExplorerTree"
                          ItemsSource="{Binding ExplorerRoots}"
                          BorderThickness="0"
                          FontSize="12"
                          Background="Transparent">
                    <TreeView.Resources>
                        <ContextMenu x:Key="TreeItemMenu" x:Shared="False">
                            <MenuItem Header="Open in Explorer" Click="CtxExplore_Click">
                                <MenuItem.Icon>
                                    <ui:SymbolIcon Symbol="Open24"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="{Binding ScanActionText}" Click="CtxScan_Click">
                                <MenuItem.Icon>
                                    <ui:SymbolIcon Symbol="Search24"/>
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </TreeView.Resources>
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                            <Setter Property="ContextMenu" Value="{StaticResource TreeItemMenu}"/>
                            <EventSetter Event="MouseDoubleClick" Handler="TreeViewItem_MouseDoubleClick"/>
                        </Style>
                    </TreeView.ItemContainerStyle>
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal" Margin="0,3,0,3">
                                <Image Source="{Binding Icon}"
                                       Width="16" Height="16"
                                       Margin="0,0,6,0"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Name}" FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock Margin="10,0,0,0" Opacity="0.7" VerticalAlignment="Center" FontSize="12"
                                           Visibility="{Binding HasScanData, Converter={StaticResource BoolToVis}}">
                                    <TextBlock.Text>
                                        <MultiBinding Converter="{StaticResource MetricValueConverter}">
                                            <Binding Path="CurrentMetricValue"/>
                                            <Binding Path="DataContext.CurrentMetric" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </Border>

            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch" Background="Transparent"/>

            <Border Grid.Column="2"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Background="{DynamicResource ControlFillColorDefaultBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="12,6,8,6"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="0,0,0,1"
                            Visibility="{Binding HasLastUpdate, Converter={StaticResource BoolToVis}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{Binding LastUpdateText}"
                                           VerticalAlignment="Center"
                                           Opacity="0.85"
                                           FontSize="12"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="  (rescanning…)"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                           Visibility="{Binding IsSelectedScanning, Converter={StaticResource BoolToVis}}"/>
                            </StackPanel>
                            <ui:Button Grid.Column="1"
                                       Click="RescanSelected_Click"
                                       IsEnabled="{Binding CanRescanSelected}"
                                       Padding="8,3"
                                       ToolTip="Rescan this folder">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="ArrowSync24" FontSize="13" Margin="0,0,4,0"/>
                                    <TextBlock Text="Rescan" VerticalAlignment="Center"/>
                                </StackPanel>
                            </ui:Button>
                        </Grid>
                    </Border>
                <Grid Grid.Row="1">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="{Binding ShowEmptyHint, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Double-click a folder on the left to scan it."
                                   HorizontalAlignment="Center"
                                   Opacity="0.55" FontSize="14"/>
                        <ui:Button Content="Scan now"
                                   HorizontalAlignment="Center"
                                   Margin="0,14,0,0"
                                   Padding="14,6"
                                   IsEnabled="{Binding CanScanNow}"
                                   Click="ScanNow_Click"/>
                    </StackPanel>
                    <TextBlock Text="{Binding EmptyFolderText}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Opacity="0.55" FontSize="14"
                               Visibility="{Binding ShowEmptyFolderHint, Converter={StaticResource BoolToVis}}"/>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                Panel.ZIndex="10"
                                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                        <ui:ProgressRing IsIndeterminate="True" Width="48" Height="48" HorizontalAlignment="Center"/>
                        <TextBlock Text="Loading..." HorizontalAlignment="Center" Margin="0,12,0,0" Opacity="0.7" FontSize="13"/>
                    </StackPanel>
                    <ScrollViewer VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Disabled"
                                  Padding="0,0,2,0"
                                  Visibility="{Binding HasBarRows, Converter={StaticResource BoolToVis}}">
                        <StackPanel Margin="8,8,8,8">
                        <ItemsControl ItemsSource="{Binding BarRows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="BarTrack" Height="52" Margin="0,3,0,3"
                                            CornerRadius="4"
                                            Cursor="Hand"
                                            Background="{DynamicResource BarTrackBrush}"
                                            MouseLeftButtonUp="BarRow_Click">
                                        <Border.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Open in default application" Click="BarRowOpenDefault_Click"
                                                          Visibility="{Binding IsDirectory, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                                                    <MenuItem.Icon>
                                                        <ui:SymbolIcon Symbol="Play24"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="Show in Explorer" Click="BarRowShowInExplorer_Click">
                                                    <MenuItem.Icon>
                                                        <ui:SymbolIcon Symbol="Open24"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="Properties" Click="BarRowProperties_Click">
                                                    <MenuItem.Icon>
                                                        <ui:SymbolIcon Symbol="Info24"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="Expand in navigation tree" Click="BarRowExpand_Click"
                                                          Visibility="{Binding IsDirectory, Converter={StaticResource BoolToVis}}">
                                                    <MenuItem.Icon>
                                                        <ui:SymbolIcon Symbol="ArrowExpand24"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="Rescan" Click="CtxBarScan_Click"
                                                          Visibility="{Binding IsDirectory, Converter={StaticResource BoolToVis}}">
                                                    <MenuItem.Icon>
                                                        <ui:SymbolIcon Symbol="ArrowSync24"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <Separator/>
                                                <MenuItem Header="Delete" Click="BarRowRecycle_Click">
                                                    <MenuItem.Icon>
                                                        <ui:SymbolIcon Symbol="Delete24"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <Grid>
                                            <Border HorizontalAlignment="Left"
                                                    CornerRadius="4"
                                                    Background="{DynamicResource BarFillBrush}">
                                                <Border.Width>
                                                    <MultiBinding Converter="{StaticResource BarFractionToWidth}">
                                                        <Binding Path="BarFraction"/>
                                                        <Binding Path="ActualWidth" ElementName="BarTrack"/>
                                                    </MultiBinding>
                                                </Border.Width>
                                            </Border>
                                            <Grid Margin="12,4,12,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <Grid Grid.Column="0" Width="24" Height="24" Margin="0,0,10,0" VerticalAlignment="Center">
                                                    <Image Source="{Binding Icon}"
                                                           RenderOptions.BitmapScalingMode="HighQuality"
                                                           Visibility="{Binding IsAggregate, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"/>
                                                    <ui:SymbolIcon Symbol="Document24"
                                                                   FontSize="22"
                                                                   Visibility="{Binding IsAggregate, Converter={StaticResource BoolToVis}}"/>
                                                </Grid>

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontWeight="SemiBold"
                                                               FontSize="13"
                                                               Foreground="{DynamicResource BarTextBrush}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding MetricsSummary}"
                                                               Opacity="0.85"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource BarTextBrush}"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="0,1,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <ui:Button Content="{Binding LoadMoreBarRowsText}"
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,8"
                                   Padding="16,6"
                                   Click="LoadMoreBarRows_Click"
                                   Visibility="{Binding CanLoadMoreBarRows, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3" Padding="16,6,16,8"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Idle: single-line status. Visible only when no active scans. -->
                <TextBlock Grid.Column="0" Text="{Binding Status}"
                           TextTrimming="CharacterEllipsis"
                           Opacity="0.85"
                           VerticalAlignment="Center"
                           Visibility="{Binding ShowActiveScansPanel, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"/>

                <!-- Active: per-scan rows. Visible when any scan is running or queued. -->
                <ItemsControl Grid.Column="0"
                              ItemsSource="{Binding ActiveScans}"
                              Visibility="{Binding ShowActiveScansPanel, Converter={StaticResource BoolToVis}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,3,0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ui:ProgressRing Grid.Column="0" IsIndeterminate="True"
                                                 Width="14" Height="14" Margin="0,0,10,0"
                                                 Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}"/>
                                <ui:SymbolIcon Grid.Column="0" Symbol="Clock24"
                                               FontSize="14" Margin="0,0,10,0" Opacity="0.6"
                                               Visibility="{Binding IsPending, Converter={StaticResource BoolToVis}}"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DisplayPath}"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="  •  "
                                               VerticalAlignment="Center"
                                               Opacity="0.45" FontSize="12"/>
                                    <TextBlock Text="{Binding SummaryText}"
                                               VerticalAlignment="Center"
                                               Opacity="0.75" FontSize="12"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="{Binding ElapsedText}"
                                           VerticalAlignment="Center"
                                           Opacity="0.75" FontSize="12"
                                           Margin="10,0,0,0"
                                           Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}"/>
                                <ui:Button Grid.Column="3" Padding="4,2"
                                           Margin="8,0,0,0"
                                           Click="CancelJob_Click"
                                           Tag="{Binding}"
                                           ToolTip="Cancel this scan">
                                    <ui:SymbolIcon Symbol="Dismiss24" FontSize="13"/>
                                </ui:Button>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ui:Button Grid.Column="1" Padding="4"
                           Margin="10,0,0,0"
                           VerticalAlignment="Center"
                           ToolTip="Database"
                           Click="Database_Click">
                    <ui:SymbolIcon Symbol="Database24"/>
                </ui:Button>
                <ui:Button Grid.Column="2" Padding="4"
                           Margin="6,0,0,0"
                           VerticalAlignment="Center"
                           ToolTip="Settings"
                           Click="Settings_Click">
                    <ui:SymbolIcon Symbol="Settings24"/>
                </ui:Button>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
